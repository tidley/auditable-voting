# Auditable Voting Worker configuration
# Copy this file to .env and fill in the values before running `make install-worker`.

# Required
WORKER_NSEC=nsec1...
COORDINATOR_NPUB=npub1...

# Optional
# WORKER_RELAYS=wss://relay.nostr.net,wss://nos.lol
# RUST_LOG=info
# WORKER_STATE_DIR=/var/lib/auditable-voting-worker
# WORKER_HEARTBEAT_SECONDS=30
# WORKER_POLL_SECONDS=15
