{
  "name": "auditable-voting-web",
  "private": true,
  "version": "0.1.49",
  "type": "module",
  "scripts": {
    "build:wasm": "npm run build:wasm:legacy && npm run build:wasm:coordinator",
    "build:wasm:legacy": "cd rust-core && wasm-pack build --target bundler --out-dir ../src/wasm/auditable_voting_core/pkg",
    "build:wasm:coordinator": "cd ../auditable-voting-core && wasm-pack build --target bundler --out-dir ../web/src/wasm/auditable_voting_coordinator_core/pkg -- --features openmls-engine",
    "predev": "node scripts/ensure-wasm-artifacts.mjs",
    "prebuild": "node scripts/ensure-wasm-artifacts.mjs",
    "pretest": "node scripts/ensure-wasm-artifacts.mjs",
    "pretest:watch": "node scripts/ensure-wasm-artifacts.mjs",
    "preverify:simple-blind-shares": "node scripts/ensure-wasm-artifacts.mjs",
    "pretest:live-relays": "node scripts/ensure-wasm-artifacts.mjs",
    "pretest:live-relays:repeat": "node scripts/ensure-wasm-artifacts.mjs",
    "pretest:live-delegate-coordinator": "node scripts/ensure-wasm-artifacts.mjs",
    "pretest:live-rust-helper": "node scripts/ensure-wasm-artifacts.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "test": "vitest run",
    "test:relay-load": "vitest run src/simpleRelayLoad.test.ts",
    "test:rust": "cargo test --manifest-path rust-core/Cargo.toml",
    "test:watch": "vitest",
    "test:course-feedback-preflight": "vitest run src/questionnaireProtocol.test.ts src/questionnaireRuntime.test.ts src/questionnaireResponderIdentity.test.ts src/questionnaireTransport.test.ts src/questionnaireCourseFeedbackPreflight.test.ts",
    "verify:simple-blind-shares": "tsx scripts/verify-simple-blind-shares.ts",
    "test:live-relays": "node scripts/live-simple-relay-check.js",
    "test:live-relays:repeat": "node scripts/live-simple-relay-repeat.js",
    "test:live-delegate-coordinator": "tsx scripts/live-delegate-coordinator-smoke.ts",
    "test:live-rust-helper": "tsx scripts/live-rust-helper-smoke.ts"
  },
  "dependencies": {
    "@cloudflare/blindrsa-ts": "^0.4.5",
    "@noble/hashes": "^2.0.1",
    "jsqr": "^1.4.0",
    "nostr-tools": "^2.7.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.0",
    "wasm-pack": "^0.14.0"
  }
}
